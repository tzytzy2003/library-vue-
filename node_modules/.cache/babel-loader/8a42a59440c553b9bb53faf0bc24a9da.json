;AAAA;AAAA;AAAA;AACA;AACA,gBAAA,OAFA,GAEA,MAAA,CAAA,QAAA,CAAA,IAAA,CAAA,QAAA,CAAA,cAAA,CAAA,OAAA,CAAA,CAFA,EAIA;;AACA,gBAAA,MALA,GAKA;AACA,kBAAA,KAAA,EAAA;AACA,oBAAA,IAAA,EAAA;AADA,mBADA;AAIA,kBAAA,KAAA,EAAA;AACA,oBAAA,IAAA,EAAA,EADA;AAEA,oBAAA,SAAA,EAAA;AACA;AACA,sBAAA,IAAA,EAAA,IAFA;AAGA,sBAAA,QAAA,EAAA,CAHA;AAGA;AACA,sBAAA,SAAA,EAAA,mBAAA,MAAA,EAAA;AACA,4BAAA,aAAA,GAAA,EAAA;AACA,4BAAA,gBAAA,GAAA,MAAA,CAAA,MAAA;AACA,4BAAA,aAAA,GAAA,CAAA,CAHA,CAGA;;AACA,4BAAA,SAAA,GAAA,IAAA,CAAA,IAAA,CAAA,gBAAA,GAAA,aAAA,CAAA;;AACA,4BAAA,gBAAA,GAAA,aAAA,EAAA;AACA,+BAAA,IAAA,CAAA,GAAA,CAAA,EAAA,CAAA,GAAA,SAAA,EAAA,CAAA,EAAA,EAAA;AACA,gCAAA,OAAA,GAAA,EAAA;AACA,gCAAA,KAAA,GAAA,CAAA,GAAA,aAAA;AACA,gCAAA,GAAA,GAAA,KAAA,GAAA,aAAA;;AACA,gCAAA,CAAA,IAAA,SAAA,GAAA,CAAA,EAAA;AACA,8BAAA,OAAA,GAAA,MAAA,CAAA,SAAA,CAAA,KAAA,EAAA,gBAAA,CAAA;AACA,6BAFA,MAEA;AACA,8BAAA,OAAA,GAAA,MAAA,CAAA,SAAA,CAAA,KAAA,EAAA,GAAA,IAAA,IAAA;AACA;;AACA,4BAAA,aAAA,IAAA,OAAA;AACA;AACA,yBAZA,MAYA;AACA,0BAAA,aAAA,GAAA,MAAA;AACA;;AACA,+BAAA,aAAA;AACA;AAzBA;AAFA,mBAJA;AAkCA,kBAAA,KAAA,EAAA,EAlCA;AAmCA,kBAAA,MAAA,EAAA,CACA;AACA,oBAAA,IAAA,EAAA,IADA;AAEA,oBAAA,IAAA,EAAA,KAFA;AAGA,oBAAA,IAAA,EAAA;AAHA,mBADA;AAnCA,iBALA,EAgDA;;AAhDA;AAAA,uBAiDA,gBAAA,EAjDA;;AAAA;AAiDA,gBAAA,GAjDA;;AAkDA,oBAAA,GAAA,IAAA,GAAA,CAAA,IAAA,IAAA,GAAA,EAAA;AACA,kBAAA,OAAA,CAAA,GAAA,CAAA,MAAA;AACA,kBAAA,OAAA,CAAA,GAAA,CAAA,GAAA;AACA,kBAAA,MAAA,CAAA,KAAA,CAAA,IAAA,GAAA,GAAA,CAAA,IAAA,CAAA,KAAA;AACA,kBAAA,MAAA,CAAA,MAAA,CAAA,CAAA,EAAA,IAAA,GAAA,GAAA,CAAA,IAAA,CAAA,MAAA;AACA,iBAvDA,CAwDA;;;AACA,gBAAA,OAAA,CAAA,SAAA,CAAA,MAAA;;AAzDA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AA0DA,KArGA;AAsGA,IAAA,SAtGA,uBAsGA;AAAA;;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AACA;AACA,gBAAA,OAFA,GAEA,MAAA,CAAA,QAAA,CAAA,IAAA,CAAA,QAAA,CAAA,cAAA,CAAA,OAAA,CAAA,CAFA,EAIA;;AACA,gBAAA,MALA,GAKA;AACA,kBAAA,KAAA,EAAA;AACA,oBAAA,IAAA,EAAA,SADA;AAEA,oBAAA,IAAA,EAAA;AAFA,mBADA;AAKA,kBAAA,OAAA,EAAA;AACA,oBAAA,OAAA,EAAA;AADA,mBALA;AAQA,kBAAA,MAAA,EAAA;AACA,oBAAA,MAAA,EAAA,UADA;AAEA,oBAAA,IAAA,EAAA;AAFA,mBARA;AAYA,kBAAA,MAAA,EAAA,CACA;AACA,oBAAA,IAAA,EAAA,MADA;AAEA,oBAAA,IAAA,EAAA,KAFA;AAGA,oBAAA,MAAA,EAAA,CAAA,KAAA,EAAA,KAAA,CAHA;AAIA,oBAAA,IAAA,EAAA,EAJA;AAKA,oBAAA,QAAA,EAAA;AACA,sBAAA,SAAA,EAAA;AACA,wBAAA,UAAA,EAAA,EADA;AAEA,wBAAA,aAAA,EAAA,CAFA;AAGA,wBAAA,WAAA,EAAA;AAHA;AADA;AALA,mBADA;AAZA,iBALA,EAiCA;;AAjCA;AAAA,uBAkCA,aAAA,EAlCA;;AAAA;AAkCA,gBAAA,GAlCA;;AAmCA,oBAAA,GAAA,IAAA,GAAA,CAAA,IAAA,IAAA,GAAA,EAAA;AACA,kBAAA,OAAA,CAAA,GAAA,CAAA,MAAA;AACA,kBAAA,OAAA,CAAA,GAAA,CAAA,GAAA;AACA,kBAAA,MAAA,CAAA,MAAA,CAAA,CAAA,EAAA,IAAA,GAAA,GAAA,CAAA,IAAA;AACA,iBAvCA,CAwCA;;;AACA,gBAAA,OAAA,CAAA,SAAA,CAAA,MAAA;;AAzCA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AA0CA,KAhJA;AAiJA;AACA,IAAA,OAlJA,qBAkJA;AAAA;;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,uBACA,UAAA,CAAA,MAAA,CAAA,QAAA,CADA;;AAAA;AACA,gBAAA,GADA;;AAEA,oBAAA,GAAA,IAAA,GAAA,CAAA,IAAA,IAAA,GAAA,EAAA;AACA,kBAAA,OAAA,CAAA,GAAA,CAAA,GAAA,EADA,CAEA;;AACA,kBAAA,MAAA,CAAA,SAAA,GAAA,GAAA,CAAA,IAAA,CAAA,OAAA;AACA,kBAAA,MAAA,CAAA,QAAA,CAAA,KAAA,GAAA,GAAA,CAAA,IAAA,CAAA,KAAA;AACA;;AAPA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAQA;AA1JA;AAxBA,CAAA","sourcesContent":["<template>\n  <el-main>\n    <div id=\"title\">\n      数据统计\n    </div>\n    <hr>\n    <div style=\"display: flex\">\n      <div id=\"main2\" style=\"width: 395px; height: 300px; flex-grow: 1\"></div>\n      <div id=\"main1\" style=\"width: 395px; height: 300px; flex-grow: 1\"></div>\n    </div>\n\n    <!-- 管理员统计 -->\n    <el-row :gutter=\"20\" type=\"flex\" class=\"row-bg\" justify=\"center\" style=\"margin-bottom: 80px\">\n      <el-col :span=\"6\">\n        <div class=\"show-header\" style=\"background: rgb(0,191,255)\">\n          <div class=\"show-num\">{{ readerCount }}</div>\n          <div class=\"bottom-text\"> 读者总数</div>\n        </div>\n      </el-col>\n      <el-col :span=\"6\">\n        <div class=\"show-header\" style=\"background: rgb(100,149,237)\">\n          <div class=\"show-num\">{{ applyReader }}</div>\n          <div class=\"bottom-text\"> 读者待审核</div>\n        </div>\n      </el-col>\n      <el-col :span=\"6\">\n        <div class=\"show-header\" style=\"background: rgb(60,179,113)\">\n          <div class=\"show-num\">{{ borrowApplyCount }}</div>\n          <div class=\"bottom-text\"> 借书待审核</div>\n        </div>\n      </el-col>\n      <el-col :span=\"6\">\n        <div class=\"show-header\" style=\"background: rgb(237, 64, 20)\">\n          <div class=\"show-num\">{{ borrowReturnCount }}</div>\n          <div class=\"bottom-text\"> 到期待还书</div>\n        </div>\n      </el-col>\n    </el-row>\n    <el-card class=\"box-card\" style=\"margin-top: 30px\">\n      <div slot=\"header\" class=\"announcement\">\n        <span style=\"color: #000000; font-weight: 600\"> 公告列表</span>\n      </div>\n      <div v-for=\"o in noticeList\" :key=\"o.noticeId\" class=\"text item\">\n        <span style=\"font-weight:600;font-size:14px;\">{{ o.noticeTitle }}</span><span\n          style=\"margin-left:30px;font-size:14px\">{{ o.noticeContent }}</span>\n        <el-divider></el-divider>\n      </div>\n    </el-card>\n  </el-main>\n</template>\n\n<script>\nimport { getUserType, getUserId } from '@/utils/auth'\nimport { getReaderCountApi, getApplyReaderCountApi } from '@/api/reader'\nimport { getBorrowApplyCountApi, getBorrowReturnCountApi } from '@/api/borrow'\nimport { categoryCountApi } from '@/api/category'\nimport { getHotBookApi } from '@/api/book'\nimport { getTopListApi } from '@/api/notice'\nimport { getListApi } from '@/api/role'\n\nexport default {\n  name: 'Dashboard',\n  data() {\n    return {\n      readerCount: 0,\n      applyReader: 0,\n      borrowApplyCount: 0,\n      borrowReturnCount: 0,\n      noticeList: [],\n      roleType: '',\n      tableData: [],\n      // 角色Id\n      roleId: ''\n    }\n  },\n  mounted() {\n    this.myechert1()\n    this.myechert2()\n    this.getReaderCount()\n    this.getApplyReaderCount()\n    this.getBorrowApplyCount()\n    this.getBorrowReturnCount()\n    this.getNoticeList()\n  },\n  methods: {\n    async getNoticeList() {\n      let res = await getTopListApi()\n      if (res && res.code == 200) {\n        console.log('公告列表')\n        console.log(res)\n        this.noticeList = res.data\n      }\n    },\n    async getBorrowReturnCount() {\n      let res = await getBorrowReturnCountApi({\n        userType: getUserType(),\n        userId: getUserId()\n      })\n      console.log(res)\n      if (res && res.code == 200) {\n        this.borrowReturnCount = res.data\n      }\n    },\n    async getBorrowApplyCount() {\n      let res = await getBorrowApplyCountApi({\n        userType: getUserType(),\n        userId: getUserId()\n      })\n      console.log(res)\n      if (res && res.code == 200) {\n        this.borrowApplyCount = res.data\n      }\n    },\n    async getReaderCount() {\n      let res = await getReaderCountApi()\n      console.log(res)\n      if (res && res.code == 200) {\n        this.readerCount = res.data\n      }\n    },\n    async getApplyReaderCount() {\n      let res = await getApplyReaderCountApi()\n      console.log(res)\n      if (res && res.code == 200) {\n        this.applyReader = res.data\n      }\n    },\n    async myechert1() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = this.$echarts.init(document.getElementById('main1'))\n\n      // 指定图表的配置项和数据\n      var option = {\n        title: {\n          text: '图书分类统计'\n        },\n        xAxis: {\n          data: [],\n          axisLabel: {\n            //x轴文字的配置\n            show: true,\n            interval: 0,//使x轴文字显示全\n            formatter: function (params) {\n              var newParamsName = \"\";\n              var paramsNameNumber = params.length;\n              var provideNumber = 3; //一行显示几个字\n              var rowNumber = Math.ceil(paramsNameNumber / provideNumber);\n              if (paramsNameNumber > provideNumber) {\n                for (var p = 0; p < rowNumber; p++) {\n                  var tempStr = \"\";\n                  var start = p * provideNumber;\n                  var end = start + provideNumber;\n                  if (p == rowNumber - 1) {\n                    tempStr = params.substring(start, paramsNameNumber);\n                  } else {\n                    tempStr = params.substring(start, end) + \"\\n\";\n                  }\n                  newParamsName += tempStr;\n                }\n              } else {\n                newParamsName = params;\n              }\n              return newParamsName;\n            }\n          }\n        },\n        yAxis: {},\n        series: [\n          {\n            name: '数量',\n            type: 'bar',\n            data: []\n          }\n        ]\n      }\n      // 动态获取数据\n      let res = await categoryCountApi()\n      if (res && res.code == 200) {\n        console.log('分类数据')\n        console.log(res)\n        option.xAxis.data = res.data.names\n        option.series[0].data = res.data.counts\n      }\n      // 使用刚指定的配置项和数据显示图表。\n      myChart.setOption(option)\n    },\n    async myechert2() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = this.$echarts.init(document.getElementById('main2'))\n\n      // 指定图表的配置项和数据\n      var option = {\n        title: {\n          text: '热门图书排行榜',\n          left: 'center'\n        },\n        tooltip: {\n          trigger: 'item'\n        },\n        legend: {\n          orient: 'vertical',\n          left: 'left'\n        },\n        series: [\n          {\n            name: '借阅次数',\n            type: 'pie',\n            radius: ['40%', '70%'],\n            data: [],\n            emphasis: {\n              itemStyle: {\n                shadowBlur: 10,\n                shadowOffsetX: 0,\n                shadowColor: 'rgba(0, 0, 0, 0.5)'\n              }\n            }\n          }\n        ]\n      }\n      // 动态获取数据\n      let res = await getHotBookApi()\n      if (res && res.code == 200) {\n        console.log('热门图书')\n        console.log(res)\n        option.series[0].data = res.data\n      }\n      // 使用刚指定的配置项和数据显示图表。\n      myChart.setOption(option)\n    },\n    // 获取列表\n    async getList() {\n      const res = await getListApi(this.listParm)\n      if (res && res.code == 200) {\n        console.log(res)\n        // 设置表格数据\n        this.tableData = res.data.records\n        this.listParm.total = res.data.total\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.bottom-text {\n  bottom: 0;\n  width: 100%;\n  background: rgba(0, 0, 0, 0.1);\n  text-align: center;\n  position: absolute;\n  padding: 10px;\n}\n\n#title {\n  height: 50px;\n  font-size: 30px\n}\n\n.show-header {\n  background: #00c0ef;\n  color: #fff;\n  height: 200px;\n  border-radius: 5px;\n  position: relative;\n}\n\n.show-num {\n  font-size: 60px;\n  font-weight: 600;\n  padding: 40px 0 0 0;\n  text-align: center;\n}\n</style>\n"],"sourceRoot":"src/views/dashboard"}]}