AAA,kBAaVP,EAAE,CAACQ,IAAH,KAAY,QAbF;AAAA;AAAA;AAAA;;AAcZ;AACAN,YAAAA,IAAI,CAAC;AAAEM,cAAAA,IAAI,EAAE;AAAR,aAAD,CAAJ;AACAf,YAAAA,SAAS,CAACgB,IAAV;AAhBY;AAAA;;AAAA;AAkBZ;AACA;AACMC,YAAAA,QApBM,GAoBKnB,KAAK,CAACoB,OAAN,CAAcC,KAAd,IAAuBrB,KAAK,CAACoB,OAAN,CAAcC,KAAd,CAAoBC,MAApB,GAA6B,CApBzD;;AAAA,iBAqBRH,QArBQ;AAAA;AAAA;AAAA;;AAsBV;AACAR,YAAAA,IAAI;AAvBM;AAAA;;AAAA;AAAA;AAAA;AAAA,mBA6BgBX,KAAK,CAACuB,QAAN,CAAe,cAAf,CA7BhB;;AAAA;AAAA;AA6BAF,YAAAA,KA7BA,yBA6BAA,KA7BA;AAAA;AAAA,mBAiCmBrB,KAAK,CAACuB,QAAN,CAAe,2BAAf,EAA4CF,KAA5C,CAjCnB;;AAAA;AAiCFG,YAAAA,YAjCE;AAkCRC,YAAAA,OAAO,CAACC,GAAR,CAAY,QAAZ;AACAD,YAAAA,OAAO,CAACC,GAAR,CAAYF,YAAZ;AACMG,YAAAA,GApCE,GAoCI;AAAEV,cAAAA,IAAI,EAAE,GAAR;AAAaW,cAAAA,QAAQ,EAAE,MAAvB;AAA+BC,cAAAA,MAAM,EAAE;AAAvC,aApCJ;AAqCRL,YAAAA,YAAY,CAACM,IAAb,CAAkBH,GAAlB,EArCQ,CAsCR;AACA;;AACA5B,YAAAA,MAAM,CAACgC,SAAP,CAAiBP,YAAjB,EAxCQ,CA0CR;AACA;;AACAb,YAAAA,IAAI,iCAAMF,EAAN;AAAUuB,cAAAA,OAAO,EAAE;AAAnB,eAAJ;AA5CQ;AAAA;;AAAA;AAAA;AAAA;AA8CRP,YAAAA,OAAO,CAACC,GAAR,CAAY,MAAZ,EA9CQ,CA+CR;;AA/CQ;AAAA,mBAgDF1B,KAAK,CAACuB,QAAN,CAAe,iBAAf,CAhDE;;AAAA;AAiDR;AACAZ,YAAAA,IAAI,2BAAoBF,EAAE,CAACQ,IAAvB,EAAJ;AACAf,YAAAA,SAAS,CAACgB,IAAV;;AAnDQ;AAAA;AAAA;;AAAA;AAwDd;AACA;AACA,gBAAIX,SAAS,CAAC0B,OAAV,CAAkBxB,EAAE,CAACQ,IAArB,MAA+B,CAAC,CAApC,EAAuC;AACrC;AACA;AACAN,cAAAA,IAAI;AACL,aAJD,MAIO;AACL;AACA;AACAA,cAAAA,IAAI,2BAAoBF,EAAE,CAACQ,IAAvB,EAAJ;AACAf,cAAAA,SAAS,CAACgB,IAAV;AACD;;AAnEa;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,GAAlB;;AAAA;AAAA;AAAA;AAAA;AAuEAnB,MAAM,CAACmC,SAAP,CAAiB,YAAM;AACrB;AACAhC,EAAAA,SAAS,CAACgB,IAAV;AACD,CAHD","sourcesContent":["import router from './router'\nimport store from './store'\nimport { Message } from 'element-ui'\nimport NProgress from 'nprogress' // progress bar\nimport 'nprogress/nprogress.css' // progress bar style\nimport { getToken } from '@/utils/auth' // get token from cookie\nimport getPageTitle from '@/utils/get-page-title'\n\nNProgress.configure({ showSpinner: false }) // NProgress Configuration\n\nconst whiteList = ['/login'] // no redirect whitelist\n// 全局守卫路由\nrouter.beforeEach(async(to, from, next) => {\n  // start progress bar\n  NProgress.start()\n\n  // set page title\n  document.title = getPageTitle(to.meta.title)\n\n  // determine whether the user has logged in\n  // 从Cookies里面获取token\n  const hasToken = getToken()\n  // 判断token是否存在\n  if (hasToken) {\n    // 判断是否是登录，是，直接跳到首页\n    if (to.path === '/login') {\n      // if is logged in, redirect to the home page\n      next({ path: '/' })\n      NProgress.done()\n    } else {\n      // 从vuex里面获取用户的所有权限\n      // determine whether the user has obtained his permission roles through getInfo\n      const hasRoles = store.getters.roles && store.getters.roles.length > 0\n      if (hasRoles) {\n        // 有权限，直接放行\n        next()\n      } else {\n        try {\n          // get user info\n          // note: roles must be a object array! such as: ['admin'] or ,['developer','editor']\n          // 从后端服务器获取权限信息，vuex里面的user模块的getInfo方法\n          const { roles } = await store.dispatch('user/getInfo')\n\n          // generate accessible routes map based on roles\n          // 动态生成菜单和路由\n          const accessRoutes = await store.dispatch('permission/generateRoutes', roles)\n          console.log('生成动态路由')\n          console.log(accessRoutes)\n          const obj = { path: '*', redirect: '/404', hidden: true }\n          accessRoutes.push(obj)\n          // dynamically add accessible routes\n          // 动态生成路由\n          router.addRoutes(accessRoutes)\n\n          // hack method to ensure that addRoutes is complete\n          // set the replace: true, so the navigation will not leave a history record\n          next({ ...to, replace: true })\n        } catch (error) {\n          console.log('进入异常')\n          // remove token and go to login page to re-login\n          await store.dispatch('user/resetToken')\n          // Message.error(error || 'Has Error')\n          next(`/login?redirect=${to.path}`)\n          NProgress.done()\n        }\n      }\n    }\n  } else {\n    /* has no token*/\n    // 判断请求是否在白名单中\n    if (whiteList.indexOf(to.path) !== -1) {\n      // in the free login whitelist, go directly\n      // 如果在白名单，直接放行\n      next()\n    } else {\n      // 跳转到登录\n      // other pages that do not have permission to access are redirected to the login page.\n      next(`/login?redirect=${to.path}`)\n      NProgress.done()\n    }\n  }\n})\n\nrouter.afterEach(() => {\n  // finish progress bar\n  NProgress.done()\n})\n"]}]}