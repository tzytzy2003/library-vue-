{"remainingRequest":"C:\\Users\\tblx\\Desktop\\LibraryManagerVue\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\tblx\\Desktop\\LibraryManagerVue\\src\\views\\borrow\\borrowLook.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\tblx\\Desktop\\LibraryManagerVue\\src\\views\\borrow\\borrowLook.vue","mtime":1776417904326},{"path":"C:\\Users\\tblx\\Desktop\\LibraryManagerVue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1725032621291},{"path":"C:\\Users\\tblx\\Desktop\\LibraryManagerVue\\node_modules\\babel-loader\\lib\\index.js","mtime":1725032623465},{"path":"C:\\Users\\tblx\\Desktop\\LibraryManagerVue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1725032621291},{"path":"C:\\Users\\tblx\\Desktop\\LibraryManagerVue\\node_modules\\vue-loader\\lib\\index.js","mtime":1725032624330}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["borrowLook.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA8MA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"borrowLook.vue","sourceRoot":"src/views/borrow","sourcesContent":["<template>\n  <el-main>\n    <!-- 搜索栏 -->\n    <el-form :model=\"lookParm\" label-width=\"80px\" :inline=\"true\"  >\n      <el-form-item label=\"社区号码\">\n        <el-input v-model=\"lookParm.username\"/>\n      </el-form-item>\n      <el-form-item label=\"读者姓名\">\n        <el-input v-model=\"lookParm.learnNum\"/>\n      </el-form-item>\n      <el-form-item label=\"图书名称\">\n        <el-input v-model=\"lookParm.bookName\"/>\n      </el-form-item>\n      <el-form-item label=\"借书状态\">\n        <el-select v-model=\"lookParm.borrowStatus\" placeholder=\"请选择\">\n          <el-option\n            v-for=\"item in options\"\n            :key=\"item.value\"\n            :label=\"item.label\"\n            :value=\"item.value\"\n          />\n        </el-select>\n      </el-form-item>\n      <el-form-item label=\"异常状态\">\n        <el-select v-model=\"lookParm.returnStatus\" placeholder=\"请选择\">\n          <el-option\n            v-for=\"item in exceoptions\"\n            :key=\"item.value\"\n            :label=\"item.label\"\n            :value=\"item.value\"\n          />\n        </el-select>\n      </el-form-item>\n      <el-form-item label=\"到期状态\">\n        <el-select v-model=\"lookParm.timeStatus\" placeholder=\"请选择\">\n          <el-option\n            v-for=\"item in timetions\"\n            :key=\"item.value\"\n            :label=\"item.label\"\n            :value=\"item.value\"\n          />\n        </el-select>\n      </el-form-item>\n      <el-form-item label=\"审核状态\">\n        <el-select v-model=\"lookParm.applyStatus\" placeholder=\"请选择\">\n          <el-option\n            v-for=\"item in applytions\"\n            :key=\"item.value\"\n            :label=\"item.label\"\n            :value=\"item.value\"\n          />\n        </el-select>\n      </el-form-item>\n      <el-form-item>\n        <el-button    @click=\"searchBtn\"> 搜索</el-button>\n        <el-button\n          style=\"color: #ff7670\"\n            \n          @click=\"resetBtn\"\n        > 重置\n        </el-button>\n      </el-form-item>\n    </el-form>\n    <!-- 表格 -->\n    <el-table :height=\"tableHeight\" :data=\"tableData\" border stripe>\n      <el-table-column type=\"selection\" width=\"40\"/>\n      <el-table-column prop=\"bookName\" label=\"图书名称\" width=\"130\"/>\n      <el-table-column prop=\"bookPlaceNum\" label=\"书架号\"/>\n      <el-table-column prop=\"username\" label=\"社区号码\"/>\n      <el-table-column prop=\"learnNum\" label=\"读者\"/>\n      <el-table-column prop=\"className\" label=\"家庭住址\"/>\n      <el-table-column prop=\"phone\" label=\"电话\" width=\"110\"/>\n      <el-table-column prop=\"borrowTime\" label=\"借书时间\" width=\"100\"/>\n      <el-table-column prop=\"returnTime\" label=\"还书时间\" width=\"100\"/>\n      <!--      <el-table-column prop=\"applyText\" label=\"审核备注\"></el-table-column>-->\n      <el-table-column prop=\"excepionText\" label=\"还书备注\"/>\n      <el-table-column\n        prop=\"borrowStatus\"\n        label=\"借书状态\"\n        align=\"center\"\n        width=\"100\"\n      >\n        <template slot-scope=\"scope\">\n          <el-tag\n            v-if=\"scope.row.borrowStatus == '0'\"\n            type=\"danger\"\n          >审核中\n          </el-tag>\n          <el-tag v-if=\"scope.row.borrowStatus == '1'\">在借中</el-tag>\n          <el-tag\n            v-if=\"scope.row.borrowStatus == '2'\"\n            type=\"success\"\n          >已还\n          </el-tag>\n          <el-tag\n            v-if=\"scope.row.borrowStatus == '3'\"\n            type=\"danger\"\n          >拒绝\n          </el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column\n        prop=\"timeStatus\"\n        label=\"到期状态\"\n        align=\"center\"\n        width=\"100\"\n      >\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.timeStatus == '1'\" type=\"danger\">到期</el-tag>\n          <el-tag\n            v-if=\"scope.row.timeStatus == '0'\"\n            type=\"success\"\n          >未到期\n          </el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column\n        prop=\"applyStatus\"\n        label=\"审核状态\"\n        align=\"center\"\n        width=\"100\"\n      >\n        <template slot-scope=\"scope\">\n          <el-tag\n            v-if=\"scope.row.applyStatus == '0'\"\n            type=\"danger\"\n          >待审核\n          </el-tag>\n          <el-tag\n            v-if=\"scope.row.applyStatus == '1'\"\n            type=\"success\"\n          >已审核\n          </el-tag>\n          <el-tag\n            v-if=\"scope.row.applyStatus == '2'\"\n            type=\"danger\"\n          >拒绝\n          </el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column  label=\"操作\" fixed=\"right\"  width=\"200\">\n        <template slot-scope=\"scope\">\n          <el-button\n            v-if=\"scope.row.applyStatus == '0'\"\n            v-permission=\"['sys:borrowLook:apply']\"\n              \n            type=\"primary\"\n             \n            @click=\"applyBtn(scope.row)\"\n          > 同意借阅\n          </el-button>\n          <el-button\n            v-if=\"scope.row.borrowStatus == '1'\"\n            v-permission=\"['sys:borrowLook:addTime']\"\n              \n            type=\"primary\"\n             \n            @click=\"addTimeBtn(scope.row)\"\n          > 续期\n          </el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n    <!-- 分页 -->\n    <el-pagination\n      :current-page.sync=\"lookParm.currentPage\"\n      :page-sizes=\"[8, 20, 40, 80, 100]\"\n      :page-size=\"lookParm.pageSize\"\n      layout=\"total, sizes, prev, pager, next, jumper\"\n      :total=\"lookParm.total\"\n      background\n      @size-change=\"sizeChange\"\n      @current-change=\"currentChange\"\n    />\n    <!-- 续期弹框 -->\n    <sys-dialog\n      :title=\"dialog.title\"\n      :visible=\"dialog.visible\"\n      :width=\"dialog.width\"\n      :height=\"dialog.height\"\n      @onConfirm=\"onConfirm\"\n      @onClose=\"onClose\"\n    >\n      <div slot=\"content\">\n        <el-form\n          ref=\"addTime\"\n          :model=\"addTime\"\n          :rules=\"rules\"\n          label-width=\"80px\"\n          :inline=\"false\"\n           \n        >\n          <el-form-item prop=\"returnTime\" label=\"还书时间\">\n            <el-date-picker\n              v-model=\"addTime.returnTime\"\n              type=\"date\"\n              placeholder=\"选择还书时间\"\n            />\n          </el-form-item>\n        </el-form>\n      </div>\n    </sys-dialog>\n  </el-main>\n</template>\n\n<script>\nimport SysDialog from '@/components/dialog/SysDialog.vue'\nimport { getUserId } from '@/utils/auth'\nimport { getLookBorrowListApi, applyBookApi, addTimeApi } from '@/api/borrow'\n\nexport default {\n  components: {\n    SysDialog\n  },\n  data() {\n    return {\n      rules: {\n        addTime: [\n          { required: true, message: '请选择还书时间', trigger: 'blur' }\n        ]\n      },\n      addTime: {\n        borrowId: '',\n        returnTime: ''\n      },\n      dialog: {\n        title: '借书续期',\n        visible: false,\n        width: 650,\n        height: 150\n      },\n      tableHeight: 0,\n      tableData: [],\n      applytions: [\n        {\n          value: '0',\n          label: '待审核'\n        },\n        {\n          value: '1',\n          label: '已审核'\n        },\n        {\n          value: '2',\n          label: '拒绝'\n        }\n      ],\n      timetions: [\n        {\n          value: '1',\n          label: '到期'\n        },\n        {\n          value: '0',\n          label: '未到期'\n        }\n      ],\n      exceoptions: [\n        {\n          value: '1',\n          label: '正常还书'\n        },\n        {\n          value: '2',\n          label: '异常还书'\n        }\n      ],\n      options: [\n        {\n          value: '1',\n          label: '在借中'\n        },\n        {\n          value: '2',\n          label: '已还'\n        },\n        {\n          value: '3',\n          label: '拒绝'\n        }\n      ],\n      lookParm: {\n        userId: getUserId(),\n        total: 0,\n        currentPage: 1,\n        pageSize: 8,\n        username: '',\n        learnNum: '',\n        bookName: '',\n        applyStatus: '',\n        borrowStatus: '',\n        returnStatus: '',\n        timeStatus: ''\n      }\n    }\n  },\n  mounted() {\n    this.$nextTick(() => {\n      this.tableHeight = window.innerHeight - 250\n    })\n  },\n  created() {\n    this.getLookBorrowList()\n  },\n  methods: {\n    onClose() {\n      this.dialog.visible = false\n    },\n    onConfirm() {\n      this.$refs.addTime.validate(async(valid) => {\n        if (valid) {\n          const res = await addTimeApi(this.addTime)\n          if (res && res.code == 200) {\n            this.$message.success(res.msg)\n            this.getLookBorrowList()\n            this.dialog.visible = false\n          }\n        }\n      })\n    },\n    // 借书续期\n    addTimeBtn(row) {\n      console.log(row)\n      this.addTime.borrowId = row.borrowId\n      this.dialog.visible = true\n    },\n    async applyBtn(row) {\n      console.log(row)\n      const confirm = await this.$myconfirm('确定审核吗?')\n      if (confirm) {\n        const res = await applyBookApi({ borrowId: row.borrowId })\n        if (res && res.code == 200) {\n          this.$message.success(res.msg)\n          this.getLookBorrowList()\n        }\n      }\n    },\n    searchBtn() {\n      this.getLookBorrowList()\n    },\n    resetBtn() {\n      // 清空表单\n      this.lookParm.username = ''\n      this.lookParm.learnNum = ''\n      this.lookParm.bookName = ''\n      this.lookParm.applyStatus = ''\n      this.lookParm.borrowStatus = ''\n      this.lookParm.returnStatus = ''\n      this.lookParm.timeStatus = ''\n      this.getLookBorrowList()\n    },\n    currentChange(val) {\n      this.lookParm.currentPage = val\n      this.getLookBorrowList()\n    },\n    sizeChange(val) {\n      this.lookParm.pageSize = val\n      this.getLookBorrowList()\n    },\n    async getLookBorrowList() {\n      const res = await getLookBorrowListApi(this.lookParm)\n      if (res && res.code == 200) {\n        this.tableData = res.data.records\n        this.lookParm.total = res.data.total\n      }\n    }\n  }\n}\n</script>\n\n<style>\n</style>\n"]}]}